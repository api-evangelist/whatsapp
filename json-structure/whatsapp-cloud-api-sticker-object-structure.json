{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/whatsapp/refs/heads/main/json-structure/whatsapp-cloud-api-sticker-object-structure.json",
  "name": "StickerObject",
  "description": "StickerObject from WhatsApp API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Media ID from upload",
      "example": "wamid.abc123"
    },
    "link": {
      "type": "string",
      "format": "uri",
      "description": "HTTPS URL of the sticker (WebP format)",
      "example": "example_value"
    }
  }
}