{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/whatsapp/refs/heads/main/json-schema/whatsapp-cloud-api-location-message-schema.json",
  "title": "LocationMessage",
  "description": "LocationMessage from WhatsApp API",
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "example": 42.5
    },
    "longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "example": 42.5
    },
    "name": {
      "type": "string",
      "description": "Location name",
      "example": "Example Business"
    },
    "address": {
      "type": "string",
      "description": "Location address",
      "example": "example_value"
    }
  },
  "required": [
    "latitude",
    "longitude"
  ]
}